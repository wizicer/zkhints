---
import { Image } from "astro:assets";
import hintaIcon from "../assets/hinta_icon.png";
import githubIcon from "../assets/icons/github.svg";
import twitterIcon from "../assets/icons/twitter.svg";
import hatIcon from "../assets/icons/hat.svg";
import {
  defaultLanguage,
  languageLabels,
  languages,
  localizedPath,
  t,
  withLanguagePrefix,
  type Language,
} from "../i18n";

interface Props {
  lang?: Language;
}

const lang = Astro.props.lang || defaultLanguage;
const currentPath = Astro.url.pathname;
const socialAccount = lang === "ja" ? "trainbit_jp" : "icerdesign";

const socialLinks = [
  {
    href: "https://github.com/wizicer/zkhints",
    icon: githubIcon,
    alt: "GitHub",
    title: "GitHub",
    external: true,
  },
  {
    href: `https://twitter.com/${socialAccount}`,
    icon: twitterIcon,
    alt: "Twitter",
    title: "Twitter",
    external: true,
  },
  {
    href: withLanguagePrefix("/about", lang),
    icon: hatIcon,
    alt: "ZKHints",
    title: t("about", lang),
    external: false,
  },
];
---

<header class="py-4 border-b border-gray-100">
  <div class="container mx-auto px-4 flex justify-between items-center">
    <div class="flex items-center space-x-4">
      <a
        href={localizedPath("/", lang)}
        class="text-lg font-bold text-gray-900 hover:text-blue-600 transition-colors flex items-center gap-2"
      >
        <Image src={hintaIcon} alt="ZK Hints Icon" width={24} height={24} />
        ZK Hints
      </a>
      <nav class="hidden md:flex space-x-1">
        <a
          href={localizedPath("/", lang)}
          class="hidden px-3 py-2 text-sm text-gray-600 hover:text-blue-600 transition-colors"
        >
          {t("home", lang)}
        </a>
        <a
          href={localizedPath("/about", lang)}
          class="hidden px-3 py-2 text-sm text-gray-600 hover:text-blue-600 transition-colors"
        >
          {t("about", lang)}
        </a>
      </nav>
    </div>

    <div class="flex items-center space-x-4">
      <label class="sr-only" for="language-switcher">{t("language", lang)}</label>
      <select
        id="language-switcher"
        class="text-sm border border-gray-200 rounded-md bg-white px-2 py-1 text-gray-700"
        aria-label={t("language", lang)}
      >
        {
          languages.map((language) => (
            <option value={localizedPath(currentPath, language)} selected={language === lang}>
              {languageLabels[language]}
            </option>
          ))
        }
      </select>
      {
        socialLinks.map((link) => (
          <a
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noopener noreferrer" : undefined}
            class="group text-gray-500 hover:text-gray-900 transition-colors"
            title={link.title}
          >
            <Image
              src={link.icon}
              alt={link.alt}
              width="20"
              height="20"
              class="group-hover:opacity-50"
            />
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  const switcher = document.getElementById("language-switcher") as HTMLSelectElement | null;
  switcher?.addEventListener("change", () => {
    const selected = switcher.options[switcher.selectedIndex];
    const nextUrl = selected.value;
    localStorage.setItem("zkHintsLanguage", selected.text.includes("日本語") ? "ja" : "en");
    window.location.href = nextUrl;
  });
</script>

---
import SearchBar from "./SearchBar";
import ItemSection from "./ItemSection.astro";
import RecentNews from "./RecentNews.astro";
import { Image } from "astro:assets";
import hintaIcon from "../assets/hinta.png";
import { getSections } from "../data/index";
import { homeCopy, localize, type Language } from "../i18n";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const sections = getSections(lang);
---

<main class="p-6 md:px-8 mx-auto">
  <div class="my-12 text-center">
    <h1
      class="font-extrabold tracking-tight text-5xl text-zinc-950 flex items-center justify-center gap-3"
    >
      <Image src={hintaIcon} alt="ZK Hints Icon" width={120} height={120} />
      ZK Hints
    </h1>
    <p class="text-xl mt-4">
      {localize(homeCopy.intro, lang)}
      <a href="https://twitter.com/icerdesign" class="text-blue-600 hover:underline">
        @icerdesign
      </a>
      {localize(homeCopy.introTail, lang)}
    </p>
  </div>

  <div role="banner">
    <SearchBar client:load lang={lang} />
    <div class="mt-8"></div>
  </div>

  <div class="mb-12">
    <RecentNews lang={lang} />
  </div>

  <div class="pages-list" role="main">
    {sections.map((section) => <ItemSection lang={lang} title={section.title} items={section.items} />)}
  </div>
</main>

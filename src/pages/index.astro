---
import Layout from "../layouts/Layout.astro";
import HomePage from "../components/HomePage.astro";
import { defaultLanguage } from "../i18n";
---

<Layout>
  <HomePage lang={defaultLanguage} />
</Layout>

<script>
  const savedLanguage = localStorage.getItem("zkHintsLanguage");
  const browserLanguages = navigator.languages || [navigator.language];
  const prefersJapanese = browserLanguages.some((language) =>
    language.toLowerCase().startsWith("ja")
  );

  if (!savedLanguage && prefersJapanese && window.location.pathname === "/") {
    window.location.replace("/ja/");
  }
</script>

---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import hintaIcon from "../../assets/hinta.png";
import hintaMuppet from "../../assets/hinta/muppet/front.jpg";
import hintaMuppetDeparted from "../../assets/hinta/muppet/departed.jpg";
import aliceBulb from "../../assets/role/alice.png";
import bobBulb from "../../assets/role/bob.png";
import eveBulb from "../../assets/role/eve.png";
import malloryBulb from "../../assets/role/mallory.png";
---

<Layout title="ZK Hints について">
  <main class="container mx-auto px-4 py-8 max-w-4xl">
    <!-- Hero Section with Animation -->
    <div
      class="relative overflow-hidden bg-gradient-to-br from-purple-50 to-blue-50 rounded-xl p-10 mb-16 shadow-lg"
    >
      <div class="absolute top-0 left-0 w-full h-full">
        <div
          class="absolute top-10 left-10 w-20 h-20 bg-purple-200 rounded-full opacity-20 animate-pulse"
        >
        </div>
        <div
          class="absolute bottom-10 right-10 w-32 h-32 bg-blue-200 rounded-full opacity-20 animate-pulse"
          style="animation-delay: 1s;"
        >
        </div>
        <div
          class="absolute top-1/2 right-1/4 w-16 h-16 bg-indigo-200 rounded-full opacity-20 animate-pulse"
          style="animation-delay: 2s;"
        >
        </div>
      </div>

      <div class="flex items-center gap-12 relative z-10">
        <div class="flex-shrink-0">
          <div
            class="p-2 bg-purple-50 rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300"
          >
            <Image
              src={hintaMuppet}
              alt="zkHints Logo"
              class="w-40 h-auto hover:scale-105 rounded-lg transition-transform duration-300"
            />
          </div>
        </div>

        <div>
          <h1
            class="text-5xl font-bold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-purple-600 to-blue-500"
          >
            ZK Hints について
          </h1>
          <div class="w-24 h-1 bg-gradient-to-r from-purple-500 to-blue-500 mb-6"></div>
          <p class="text-xl text-gray-700">
            Zero-Knowledge Proofs の世界を探求する開発者、研究者、愛好家のための
            厳選されたナレッジベースです。
          </p>
        </div>
      </div>
    </div>

    <div class="prose max-w-none">
      <p class="leading-relaxed">
        <strong class="text-purple-600">zkHints</strong> へようこそ。これは
        <strong
          class="text-blue-600">Zero-Knowledge Proofs (ZKPs)</strong
        > の世界を探求する開発者、研究者、愛好家のための厳選されたナレッジベースです。
      </p>

      <p class="mt-3 leading-relaxed">
        ZK を学び始めたばかりの人にも、深い技術比較を探している人にも、
        zkHints はチートシート、参考資料、学習パスを少しずつ増やしながら提供します。
        目指しているのは、ZK をより身近で、実践的で、楽しく扱えるようにすることです。
      </p>

      <!-- Why zkHints Section -->
      <section
        class="my-16 bg-white rounded-xl p-8 shadow-lg transform hover:scale-[1.01] transition-transform duration-300"
      >
        <div class="flex flex-col gap-8">
          <div class="flex items-center justify-between">
            <div class="flex items-center flex-1">
              <div
                class="w-12 h-12 bg-yellow-100 rounded-full flex items-center justify-center mr-4 shadow-sm"
              >
                <span class="text-2xl">✨</span>
              </div>
              <div>
                <h2
                  class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-yellow-500 to-orange-500"
                >
                  なぜ zkHints?
                </h2>
                <p class="mt-2 leading-relaxed">
                  Zero-Knowledge 技術は急速に進化していますが、学習リソースは散らばりがちで、
                  理論寄りすぎたり、追いかけにくかったりします。zkHints は次のために作りました。
                </p>
              </div>
            </div>
            <div class="flex-shrink-0 p-2 bg-purple-50 rounded-lg shadow-md">
              <Image src={hintaMuppetDeparted} alt="zkp departed" class="w-auto h-40 rounded-lg" />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div
              class="bg-yellow-50 p-4 rounded-lg border-l-4 border-yellow-400 hover:shadow-md transition-shadow"
            >
              <div class="flex items-center mb-2">
                <span class="text-xl mr-2">📚</span>
                <h3 class="font-bold text-yellow-700">開発者向けチートシート</h3>
              </div>
              <p class="text-sm text-gray-700">
                ZK システム、言語、ガジェット、基本部品、応用例のための
                開発者向け <strong>チートシート</strong> を提供します
              </p>
            </div>

            <div
              class="bg-blue-50 p-4 rounded-lg border-l-4 border-blue-400 hover:shadow-md transition-shadow"
            >
              <div class="flex items-center mb-2">
                <span class="text-xl mr-2">🧭</span>
                <h3 class="font-bold text-blue-700">学習ロードマップ</h3>
              </div>
              <p class="text-sm text-gray-700">
                初学者から上級者まで、ZK 学習者向けの <strong>段階的なロードマップ</strong>
                を提供します
              </p>
            </div>

            <div
              class="bg-green-50 p-4 rounded-lg border-l-4 border-green-400 hover:shadow-md transition-shadow"
            >
              <div class="flex items-center mb-2">
                <span class="text-xl mr-2">🧰</span>
                <h3 class="font-bold text-green-700">実践重視</h3>
              </div>
              <p class="text-sm text-gray-700">
                ツール、実際のユースケース、実装上の詳細に焦点を当て、
                実践的な内容を重視します
              </p>
            </div>

            <div
              class="bg-purple-50 p-4 rounded-lg border-l-4 border-purple-400 hover:shadow-md transition-shadow"
            >
              <div class="flex items-center mb-2">
                <span class="text-xl mr-2">🎓</span>
                <h3 class="font-bold text-purple-700">研究の要点</h3>
              </div>
              <p class="text-sm text-gray-700">
                基礎となる <strong>論文</strong>、用語、活発な研究領域を紹介します
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Meet the Bulb Wizard Section -->
      <section class="my-16 bg-gradient-to-br from-indigo-50 to-purple-50 rounded-xl p-8 shadow-lg">
        <div class="flex items-center mb-6">
          <div
            class="w-12 h-12 bg-indigo-100 rounded-full flex items-center justify-center mr-4 shadow-sm"
          >
            <span class="text-2xl">🧙‍♂️</span>
          </div>
          <h2
            class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-500 to-purple-500"
          >
            Bulb Wizard について
          </h2>
        </div>

        <div class="flex flex-col md:flex-row items-center gap-8">
          <div class="md:w-1/2">
            <p class="leading-relaxed">
              私たちのマスコット <strong class="text-indigo-600">Crystal Bulb Wizard</strong> は、
              知識の光と、Zero-Knowledge の概念をクリアに伝えたいという思いを象徴しています。
            </p>
            <p class="leading-relaxed mt-4">
              友だちの <strong class="text-pink-600">Alice</strong>、<strong
                class="text-indigo-600">Bob</strong
              >、<strong class="text-green-600">Eve</strong>、<strong class="text-orange-600"
                >Mallory</strong
              > も登場します。古典的な暗号プロトコルの役割を、より視覚的で楽しい形で説明するために
              電球のキャラクターとして再解釈しています。
            </p>
          </div>
          <div class="md:w-1/2 flex justify-center">
            <div class="relative w-48 h-48 flex items-center justify-center overflow-hidden">
              <Image src={hintaIcon} alt="Bulb Wizard" class="w-40 h-40" />
            </div>
            <div class="relative w-48 h-48 grid grid-cols-2 grid-rows-2 gap-1">
              <Image
                src={aliceBulb}
                alt="Alice Bulb"
                class="w-full h-full object-cover scale-x-[-1]"
              />
              <Image src={bobBulb} alt="Bob Bulb" class="w-full h-full object-cover" />
              <Image src={eveBulb} alt="Eve Bulb" class="w-full h-full object-cover" />
              <Image src={malloryBulb} alt="Mallory Bulb" class="w-full h-full object-cover" />
            </div>
          </div>
        </div>
      </section>

      <!-- Partners & Contributions Section -->
      <section
        class="my-16 bg-white rounded-xl p-8 shadow-lg transform hover:scale-[1.01] transition-transform duration-300"
      >
        <div class="flex items-center mb-6">
          <div
            class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center mr-4 shadow-sm"
          >
            <span class="text-2xl">🤝</span>
          </div>
          <h2
            class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-blue-500 to-cyan-500"
          >
            パートナーとコントリビューション
          </h2>
        </div>

        <div class="bg-blue-50 p-6 rounded-lg border border-blue-100">
          <p class="text-lg font-medium text-blue-800 mb-2">
            zkHints はコミュニティ主導で、コラボレーションを歓迎しています。
          </p>
          <p class="text-gray-700">
            コンテンツ提案、オープンソースへのコントリビューション、パートナー連携を歓迎します。
            ローンチパートナーや戦略パートナーに興味があれば、
            <a
              href="https://github.com/wizicer/zkhints"
              class="text-blue-600 hover:underline font-medium inline-flex items-center"
            >
              GitHub repository
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4 ml-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                ></path>
              </svg>
            </a> から連絡してください。
          </p>
        </div>
      </section>

      <!-- Built with Love Section -->
      <section class="my-16 bg-gradient-to-br from-pink-50 to-red-50 rounded-xl p-8 shadow-lg">
        <div class="flex items-center mb-6">
          <div
            class="w-12 h-12 bg-pink-100 rounded-full flex items-center justify-center mr-4 shadow-sm"
          >
            <span class="text-2xl">🛠️</span>
          </div>
          <h2
            class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-pink-500 to-red-500"
          >
            愛情とコードで作っています
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow text-center">
            <div
              class="w-12 h-12 bg-pink-100 rounded-full flex items-center justify-center mx-auto mb-3"
            >
              <span class="text-xl">🔍</span>
            </div>
            <h3 class="font-bold text-pink-700 mb-2">好奇心が原動力</h3>
            <p class="text-sm text-gray-600">
              複雑な概念を理解し、説明したいという思いで動いています
            </p>
          </div>

          <div class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow text-center">
            <div
              class="w-12 h-12 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-3"
            >
              <span class="text-xl">🎨</span>
            </div>
            <h3 class="font-bold text-red-700 mb-2">明快さのためのデザイン</h3>
            <p class="text-sm text-gray-600">
              複雑なトピックを近づきやすく、理解しやすくすることに集中しています
            </p>
          </div>

          <div class="bg-white p-4 rounded-lg shadow hover:shadow-md transition-shadow text-center">
            <div
              class="w-12 h-12 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-3"
            >
              <span class="text-xl">🌐</span>
            </div>
            <h3 class="font-bold text-orange-700 mb-2">コミュニティからの刺激</h3>
            <p class="text-sm text-gray-600">
              グローバルな ZK 研究・開発コミュニティとともに、そのために作っています
            </p>
          </div>
        </div>

        <p class="mt-6 text-center text-gray-700 bg-white p-4 rounded-lg shadow-inner">
          zkHints が役に立ったなら、ぜひ声を聞かせてください。フィードバック、issue、pull request も大歓迎です。
        </p>
      </section>

      <!-- Final Quote -->
      <div class="relative my-16 py-10">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-300"></div>
        </div>
        <div class="relative flex justify-center">
          <div
            class="px-8 py-4 bg-gradient-to-r from-purple-600 to-blue-600 rounded-full shadow-lg"
          >
        <p class="text-xl font-medium text-white italic">証明し続け、学び続けよう。</p>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

    "ZKP recursion と composition techniques を扱う中国語の systematic study。",
  "Discovery and fix of PLONK security vulnerability, proving statistical zero-knowledge.":
    "PLONK security vulnerability の発見と修正。statistical zero-knowledge を証明します。",
  "Security analysis showing FRI parameters have 21-63 bits less security than assumed.":
    "FRI parameters の security が想定より 21-63 bits 低いことを示す security analysis。",
  "Analysis of ZKP system vulnerabilities to CPU cache attacks with defense measures.":
    "CPU cache attacks に対する ZKP system vulnerabilities と defense measures の analysis。",
  "Tool detecting finalization failure vulnerabilities, found 12 zero-day bugs.":
    "finalization failure vulnerabilities を検出する tool。12 件の zero-day bugs を発見。",
  "Formal verification tool for BitVM with register-based DSL and CEGIS process.":
    "register-based DSL と CEGIS process を持つ BitVM 向け formal verification tool。",
};

const translateText = (text: string | undefined) =>
  text ? localizedTitles[text] || localizedDescriptions[text] || text : text;
const localizeSection = (section: ResourceSection): ResourceSection => ({
  ...section,
  title: translateText(section.title) || section.title,
  description: translateText(section.description),
  links: section.links.map((link) => ({
    ...link,
    description: "description" in link ? translateText(link.description) || link.description : link.description,
  })),
  subsections: section.subsections?.map(localizeSection),
});
const localizedResource: Resource = {
  ...resource,
  sections: resource.sections.map(localizeSection),
};
---

<Layout id={resource.id}>
  <div class="container mx-auto px-4 py-8">
    <div
      class="mb-8 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-lg shadow-lg overflow-hidden"
    >
      <div class="bg-gradient-to-r from-blue-600 to-indigo-600 px-6 py-4">
        <h2 class="text-xl font-bold text-white flex items-center">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 mr-2"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h7"></path>
          </svg>
          {t("tableOfContents", "ja")}
        </h2>
      </div>

      <div class="p-6">
        <ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {
            localizedResource.sections.map((section: ResourceSection) => (
              <li class="transform transition duration-200 hover:translate-x-1">
                <a
                  href={`#${section.id}`}
                  class="flex items-center p-3 rounded-md hover:bg-white group transition-all duration-200 hover:shadow-md"
                >
                  <span class="flex items-center justify-center w-8 h-8 mr-3 rounded-full bg-gradient-to-r from-blue-500 to-indigo-500 text-white text-lg">
                    {section.emoji}
                  </span>
                  <div class="flex flex-col">
                    <span class="font-medium text-gray-800 group-hover:text-blue-600">
                      {section.title}
                    </span>
                    {section.description && (
                      <span class="text-xs text-gray-500 truncate max-w-xs">
                        {section.description}
                      </span>
                    )}
                  </div>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 ml-auto text-gray-400 group-hover:text-blue-500"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    {
      localizedResource.sections.map((section: ResourceSection) => (
        <div class="mb-12" id={section.id}>
          <SectionHeading title={section.emoji + section.title} gradientPart={section.title} />

          {section.description && <p class="text-gray-600 mb-4">{section.description}</p>}

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {section.links.map((link) => (
              <ResourceLink link={link} lang="ja" />
            ))}
          </div>

          {section.subsections && section.subsections.length > 0 && (
            <div class="mt-8">
              {section.subsections.map((subsection) => (
                <div class="mb-8">
                  <SubsectionHeading title={subsection.emoji + " " + subsection.title} />

                  {subsection.description && (
                    <p class="text-gray-600 mb-4">{subsection.description}</p>
                  )}

                  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    {subsection.links.map((link) => (
                      <ResourceLink link={link} lang="ja" />
                    ))}
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      ))
    }

    <div class="mt-8">
      <a href={localizedPath("/", "ja")} class="inline-flex items-center text-blue-600 hover:underline">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 mr-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        {t("backToCheatsheets", "ja")}
      </a>
    </div>
  </div>
</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }

  :target {
    scroll-margin-top: 2rem;
  }
</style>

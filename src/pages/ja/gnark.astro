---
import Layout from "../../layouts/Layout.astro";
import CheatsheetSection from "../../components/CheatsheetSection";
import { getSections, recursive } from "../../data/gnark";

const sections = getSections("ja");
---

<Layout id="gnark">
  <div class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <p class="text-gray-700 mb-4">
        Gnark は zero-knowledge proof circuits を構築するための Go library です。この cheatsheet
        は、よく使う操作や pattern をすばやく参照できるようにまとめています。
      </p>
      <p class="text-gray-700 mb-4">
        <span class="font-semibold">注:</span> コード例では、 <code
          class="bg-gray-100 px-1 py-0.5 rounded">Var</code
        > は <code class="bg-gray-100 px-1 py-0.5 rounded"
          >frontend.Variable</code
        > の略記として使っています。
      </p>
      <div class="mt-6">
        <div
          class="bg-indigo-50 border border-indigo-200 rounded-lg p-4 sm:p-6 flex flex-col sm:flex-row items-start sm:items-center gap-4"
        >
          <img
            src="https://raw.githubusercontent.com/wizicer/gnark-cheatsheet/main/preview.png"
            alt="Gnark cheatsheet PDF プレビュー"
            class="w-28 h-auto rounded shadow-sm border border-gray-200"
            loading="lazy"
          />
          <div class="flex-1">
            <h3 class="text-lg font-semibold text-indigo-900 mb-1">
              印刷しやすい PDF 版を使いますか？
            </h3>
            <p class="text-indigo-900/80 mb-3">PDF は GitHub リポジトリにあります。</p>
            <a
              href="https://github.com/wizicer/gnark-cheatsheet"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-5 py-3 text-white font-semibold shadow hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition"
            >
              PDF と Repo を見る
              <svg
                class="ml-2 h-5 w-5"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14 3h7m0 0v7m0-7L10 14"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    {
      sections.map((section) => (
        <div class="mt-12 mb-4">
          <h2 class="text-2xl font-bold text-gray-800 mb-2">{section.title}</h2>
          <p class="text-gray-700">{section.description}</p>
          <CheatsheetSection title="" items={section.items} defaultLanguage="go" client:load />
        </div>
      ))
    }

    <div class="mt-16 mb-4">
      <h2 class="text-2xl font-bold text-gray-800 mb-4">再帰証明スキーム</h2>
      <p class="text-gray-700 mb-6">
        さまざまな recursive proof schemes と、その performance 特性を比較します。
      </p>
      <p class="text-gray-700 mb-6">
        比較は MacBook Pro 13" M1 Pro 上で、gnark repository の original test case を使って測定しています。
      </p>
      <div class="overflow-x-auto">
        <table class="min-w-full bg-white border border-gray-300">
          <thead>
            <tr class="bg-gray-100">
              <th class="py-2 px-4 border-b border-r">内側スキーム</th>
              <th class="py-2 px-4 border-b border-r">外側スキーム</th>
              <th class="py-2 px-4 border-b border-r">内側曲線</th>
              <th class="py-2 px-4 border-b border-r">外側曲線</th>
              <th class="py-2 px-4 border-b border-r">制約数</th>
              <th class="py-2 px-4 border-b border-r">Setup サイズ (MB)</th>
              <th class="py-2 px-4 border-b border-r">Pk サイズ (MB)</th>
              <th class="py-2 px-4 border-b border-r">制約サイズ (MB)</th>
              <th class="py-2 px-4 border-b">E2E テスト時間 (s)</th>
            </tr>
          </thead>
          <tbody>
            {
              recursive.map((scheme, index) => (
                <tr class={index % 2 === 0 ? "bg-gray-50" : "bg-white"}>
                  <td class="py-2 px-4 border-b border-r">{scheme.innerScheme}</td>
                  <td class="py-2 px-4 border-b border-r">{scheme.outerScheme}</td>
                  <td class="py-2 px-4 border-b border-r">{scheme.innerCurve}</td>
                  <td class="py-2 px-4 border-b border-r">{scheme.outerCurve}</td>
                  <td class="py-2 px-4 border-b border-r text-right">
                    {scheme.constraints.toLocaleString()}
                  </td>
                  <td class="py-2 px-4 border-b border-r text-right">
                    {scheme.setupSizeMB.toFixed(2)}
                  </td>
                  <td class="py-2 px-4 border-b border-r text-right">
                    {scheme.pkSizeMB.toFixed(2)}
                  </td>
                  <td class="py-2 px-4 border-b border-r text-right">
                    {scheme.constraintSizeMB.toFixed(2)}
                  </td>
                  <td class="py-2 px-4 border-b text-right">{scheme.e2eTestTimeS.toFixed(2)}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</Layout>

<style>
  code {
    font-family: "Fira Code", monospace;
  }

  /* Custom styling for math formulas */
  .math-formula {
    font-family: "Cambria Math", "STIX Two Math", serif;
    font-style: italic;
  }
</style>
